              ]
            },
            {
              "name": "GET /auth/profile - Token Bearer manquant (401)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "{{access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/auth/profile",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "profile"]
                },
                "description": "Token envoyé sans le préfixe 'Bearer '. Doit retourner 401."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 401 sans préfixe Bearer', function () {",
                      "  pm.response.to.have.status(401);",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]

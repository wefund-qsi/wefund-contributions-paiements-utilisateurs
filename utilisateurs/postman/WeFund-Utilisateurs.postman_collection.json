        {
          "name": "Login",
          "item": [
            {
              "name": "POST /auth/login - Succès",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"Password123!\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "login"]
                },
                "description": "Connexion avec des identifiants valides. Sauvegarde automatiquement le token JWT dans la variable `access_token`."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('Message de succès', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.message).to.equal('Login successful');",
                      "});",
                      "",
                      "pm.test('statusCode vaut 200', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.statusCode).to.equal(200);",
                      "});",
                      "",
                      "pm.test('access_token présent dans data', function () {",
                      "  const data = pm.response.json().data;",
                      "  pm.expect(data).to.have.property('access_token');",
                      "  pm.expect(data.access_token).to.be.a('string').and.not.empty;",
                      "});",
                      "",
                      "pm.test('access_token est un JWT valide (3 segments)', function () {",
                      "  const token = pm.response.json().data.access_token;",
                      "  pm.expect(token.split('.').length).to.equal(3);",
                      "});",
                      "",
                      "// Sauvegarde du token pour les requêtes suivantes",
                      "const token = pm.response.json().data?.access_token;",
                      "if (token) {",
                      "  pm.collectionVariables.set('access_token', token);",
                      "  console.log('Token sauvegardé dans access_token');",
                      "}"
                    ]
                  }
                }
              ]
            },

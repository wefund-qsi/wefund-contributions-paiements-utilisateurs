        {
          "name": "Profile",
          "item": [
            {
              "name": "GET /auth/profile - Succès (token valide)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{access_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/auth/profile",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "profile"]
                },
                "description": "Récupère le profil de l'utilisateur connecté. Utilise le token sauvegardé lors du login."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('Payload JWT contient sub', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('sub');",
                      "});",
                      "",
                      "pm.test('Payload JWT contient username', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('username');",
                      "  pm.expect(json.username).to.equal(pm.collectionVariables.get('test_username'));",
                      "});",
                      "",
                      "pm.test('Payload JWT contient role', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('role');",
                      "  const rolesValides = ['CONTRIBUTEUR', 'PORTEUR DE PROJET', 'ADMINISTRATEUR', 'VISITEUR'];",
                      "  pm.expect(rolesValides).to.include(json.role);",
                      "});",
                      "",
                      "pm.test('Payload JWT contient iat et exp', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('iat');",
                      "  pm.expect(json).to.have.property('exp');",
                      "});",
                      "",
                      "pm.test('Token non expiré', function () {",
                      "  const exp = pm.response.json().exp;",
                      "  pm.expect(exp * 1000).to.be.above(Date.now());",
                      "});"
                    ]
                  }
                }
              ]
            },

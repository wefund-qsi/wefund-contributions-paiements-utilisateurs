              "name": "POST /auth/signup - Succès (CONTRIBUTEUR)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"prenom\": \"Jean\",\n  \"nom\": \"Dupont\",\n  \"username\": \"{{test_username}}\",\n  \"password\": \"Password123!\",\n  \"role\": \"CONTRIBUTEUR\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth/signup",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "signup"]
                },
                "description": "Crée un nouvel utilisateur avec le rôle CONTRIBUTEUR."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test('Message de succès', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.message).to.equal('User, auth and role created successfully');",
                      "});",
                      "",
                      "pm.test('statusCode vaut 201', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.statusCode).to.equal(201);",
                      "});",
                      "",
                      "pm.test('data contient id, nom, prenom, username, role', function () {",
                      "  const data = pm.response.json().data;",
                      "  pm.expect(data).to.have.property('id');",
                      "  pm.expect(data).to.have.property('nom');",
                      "  pm.expect(data).to.have.property('prenom');",
                      "  pm.expect(data).to.have.property('username');",
                      "  pm.expect(data).to.have.property('role');",
                      "});",
                      "",
                      "pm.test('role est CONTRIBUTEUR', function () {",
                      "  const data = pm.response.json().data;",
                      "  pm.expect(data.role).to.equal('CONTRIBUTEUR');",
                      "});",
                      "",
                      "pm.test('timestamp présent', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('timestamp');",
                      "});"
                    ]
                  }
                }
              ]

{
  "info": {
    "_postman_id": "wefund-utilisateurs-collection",
    "name": "WeFund - Utilisateurs API",
    "description": "Collection complète du microservice utilisateurs WeFund.\n\nRoutes disponibles :\n- GET  /                    → Health check\n- POST /auth/signup         → Inscription\n- POST /auth/login          → Connexion (retourne un JWT)\n- GET  /auth/profile        → Profil (protégé JWT)\n- POST /contribution        → Créer une contribution (JWT requis)\n- GET  /contribution        → Lister mes contributions (JWT requis)\n- PATCH /contribution/:id   → Modifier le montant (JWT requis)\n- DELETE /contribution/:id  → Annuler une contribution (JWT requis)\n\nDocumentation Swagger : http://localhost:3000/api/docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

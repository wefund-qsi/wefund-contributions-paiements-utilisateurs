{
  "info": {
    "_postman_id": "wefund-utilisateurs-collection",
    "name": "WeFund - Utilisateurs API",
    "description": "Collection complète du microservice utilisateurs WeFund.\n\nRoutes disponibles :\n- GET  /             → Health check\n- POST /auth/signup  → Inscription\n- POST /auth/login   → Connexion (retourne un JWT)\n- GET  /auth/profile → Profil (protégé JWT)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_username",
      "value": "testuser_postman",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET / - Hello World",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Vérifie que le serveur est bien démarré."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Réponse Hello World', function () {",
                  "  pm.expect(pm.response.text()).to.equal('Hello World!');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "item": [
            {
              "name": "POST /auth/signup - Succès (CONTRIBUTEUR)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"prenom\": \"Jean\",\n  \"nom\": \"Dupont\",\n  \"username\": \"{{test_username}}\",\n  \"password\": \"Password123!\",\n  \"role\": \"CONTRIBUTEUR\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth/signup",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "signup"]
                },
                "description": "Crée un nouvel utilisateur avec le rôle CONTRIBUTEUR."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 201', function () {",
                      "  pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test('Message de succès', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.message).to.equal('User, auth and role created successfully');",
                      "});",
                      "",
                      "pm.test('statusCode vaut 201', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.statusCode).to.equal(201);",
                      "});",
                      "",
                      "pm.test('data contient id, nom, prenom, username, role', function () {",
                      "  const data = pm.response.json().data;",
                      "  pm.expect(data).to.have.property('id');",
                      "  pm.expect(data).to.have.property('nom');",
                      "  pm.expect(data).to.have.property('prenom');",
                      "  pm.expect(data).to.have.property('username');",
                      "  pm.expect(data).to.have.property('role');",
                      "});",
                      "",
                      "pm.test('role est CONTRIBUTEUR', function () {",
                      "  const data = pm.response.json().data;",
                      "  pm.expect(data.role).to.equal('CONTRIBUTEUR');",
                      "});",
                      "",
                      "pm.test('timestamp présent', function () {",
                      "  const json = pm.response.json();",
                      "  pm.expect(json).to.have.property('timestamp');",
                      "});"
                    ]
                  }
                }
              ]
            },

    {
      "name": "Contribution",
      "item": [
        {
          "name": "POST /contribution - Succès (campagne active)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"campagneId\": {{campagne_id}},\n  \"montant\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/contribution",
              "host": ["{{base_url}}"],
              "path": ["contribution"]
            },
            "description": "Crée une contribution sur une campagne active. Sauvegarde l'id retourné dans `contribution_id`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Message de succès', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.equal('Contribution créée avec succès');",
                  "});",
                  "",
                  "pm.test('data contient id et montant', function () {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('montant');",
                  "  pm.expect(data.montant).to.equal(50);",
                  "});",
                  "",
                  "pm.test('data contient campagne et contributeur', function () {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('campagne');",
                  "  pm.expect(data).to.have.property('contributeur');",
                  "});",
                  "",
                  "pm.test('timestamp présent', function () {",
                  "  pm.expect(pm.response.json()).to.have.property('timestamp');",
                  "});",
                  "",
                  "// Sauvegarde de l'id pour les requêtes suivantes",
                  "const id = pm.response.json().data?.id;",
                  "if (id) {",
                  "  pm.collectionVariables.set('contribution_id', id);",
                  "  console.log('contribution_id sauvegardé :', id);",
                  "}"
                ]
